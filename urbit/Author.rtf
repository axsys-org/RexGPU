    |=  [messages=(list message:ai) stream=? tools=(list tool:ai)]\
    ^-  (list card:n)\
    =/  iris=pith:t  p:(~(got by deps.bowl) %iris)\
    =/  url  !<(@t q:(~(got by q.saga) #/url))\
    =/  model  !<(@t q:(~(got by q.saga) #/model))\
    =/  =header-list:http\
      :~  ['content-type' 'application/json']\
      ==\
    =.  header-list\
      ?~  key=(~(get by q.saga) #/key)  header-list\
      =+  !<(key=@t q.u.key)\
      %^  set-header:http  'Authorization'\
        (crip "Bearer \{(trip key)\}")\
      header-list\
    =/  body=cord  (en:json:html (request:enjs:ai [messages model stream tools]))\
    =/  =octs  (as-octs:mimes:html body)\
    =/  req=tale:t\
      (~(put by *tale:t) req:slot:t iris-req/!>([%'POST' url header-list `octs]))\
    =/  stamp=tale:t\
      (~(put by *tale:t) content:slot:t noun/!>(now.bowl))\
    :~  [(snoc iris [%da now.bowl]) %make req]\
        [(snoc here.bowl %req) %make stamp]\
    ==\
  ++  get-response\
    |=  =rely:n\
    ^-  (unit [tag=?(%finished %progress) cord])\
    ?~  req=(~(get of kids.bowl) #/req)  ~\
    ?~  req=~(content sug u.req)  ~\
    =+  ;;(id=@da q.q.u.req)\
    ?~  sag=(~(get of q:(~(got by deps.bowl) %iris)) #/[da/id])  ~\
    ?~  sag=~(res sug q.u.sag)  ~\
    ?.  =(%iris-res p.u.sag)  ~\
    =+  ;;(res=client-response:http q.q.u.sag)\
    ?+  -.res  ~\
      %finished\
        ?~  full-file.res  ~\
        `[%finished ;;(@t q.data.u.full-file.res)]\
      %progress\
        ?~  incremental.res  ~\
        `[%progress ;;(@t q.u.incremental.res)]\
