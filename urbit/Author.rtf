++  seam\
  |%\
  ++  find-delim\
    |=  t=tape\
    ^-  (unit @ud)\
    =|  pos=@ud\
    |-  ^-  (unit @ud)\
    ?~  t  ~\
    ?:  ?|  =(i.t ' ')\
            =(i.t '>')\
            =(i.t '/')\
            =(i.t '\\0a')\
            =(i.t '\\09')\
        ==\
      `pos\
    $(t t.t, pos +(pos))\
    \
  ++  known-tags\
    ^-  (set cord)\
    (silt `(list cord)`~['shrub' 'dep' 'derive' 'talk' 'def'])\
\
  ++  extract-elements\
    |=  buf=tape\
    ^-  [elem=(unit manx) remainder=tape]\
    ::  find first '<'\
    =/  ope=(unit @ud)  (find "<" buf)\
    ?~  ope  [~ buf]\
    =.  buf  (slag u.ope buf)\
    ::  extract tag name after '<'\
    =/  tag=tape\
      =/  rest=tape  (slag 1 buf)\
      (scag (fall (find-delim rest) (lent rest)) rest)\
    ?~  tag       [~ buf]\
    ?.  (~(has in known-tags) (crip tag))\
      ::  not a known tag, skip this '<' and retry\
      $(buf (slag 1 buf))\
    ::  look for closing tag\
    =/  close-tag=tape  "</\{tag\}>"\
    =/  ct-len=@ud  (lent close-tag)\
    =/  clos=(unit @ud)  (find close-tag buf)\
    ?~  clos  [~ buf]\
    ::  extract complete element and remainder\
    =/  end=@ud    (add u.clos ct-len)\
    =/  block=cord  (crip (scag end buf))\
    ~&  [%ext-block block]\
    =/  rem=tape    (slag end buf)\
    ~&  [%now-rem rem]\
\
    ?~  xml=(de-xml:html block)\
      ~&  [%xml-parse-error block]\
      [~ rem]\
    ~&  [%xml xml]\
    [`u.xml rem]\
\
  ++  process-chunk\
    |=  buf=tape\
    ^-  [(list manx) tape]\
    =|  acc=(list manx)\
    ~&  [%bff buf]\
    |-\
    =/  [elem=(unit manx) remainder=tape]\
      (extract-elements buf)\
    ?~  elem  [(flop acc) remainder]\
    $(buf remainder, acc [u.elem acc])\
  ++  parse-sse\
    |=  raw=cord\
    ^-  cord\
    %-  crip\
    %-  zing\
    %+  murn  (to-wain:format raw)\
    |=  line=cord\
    ^-  (unit tape)\
    =/  t=tape  (trip line)\
    ?.  =("data: " (scag 6 t))  ~\
    =/  json-str=cord  (crip (slag 6 t))\
    ?:  =('[DONE]' json-str)  ~\
    =/  jon=(unit json)  (de:json:html json-str)\
    ?~  jon  ~\
    =/  chk=chunk:ai  (chunk:dejs:ai u.jon)\
    ?:  =(content.chk '')  ~\
    `(trip content.chk)\
