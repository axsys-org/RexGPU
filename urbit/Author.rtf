    ?~  stack  acc\
    =/  [cur=manx cur-trail=(list manx)]  i.stack\
    =/  errs=(list [term cord])\
      %+  murn  rules\
      |=  r=rule\
      ^-  (unit [term cord])\
      ?.  (ev pred.r cur state cur-trail)  ~\
      `[term.r msg.r]\
    =/  kids=(list [manx (list manx)])\
      %+  turn  c.cur\
      |=  c=manx\
      [c (snoc cur-trail cur)]\
    $(stack (weld kids t.stack), acc (weld acc errs))\
\
  ++  ev\
    |=  [p=pred nod=manx state=(list manx) trail=(list manx)]\
    ^-  ?\
    ?-  -.p\
      %h   !=('' (ga nod attr.p))\
      %k   (lien c.nod |=(c=manx =((gt c) tag.p)))\
      %g   =/  kids  ?:(=('' tag.p) c.nod (skim c.nod |=(c=manx =((gt c) tag.p))))\
           (lth (lent kids) n.p)\
      %in  (lien trail |=(m=manx =((gt m) ctx.p)))\
      %b   ?|  !(lien trail |=(m=manx =((gt m) ctx.p)))\
               !=(ref.p (cut 3 [0 (met 3 ref.p)] (ga nod 'name')))\
           ==\
      %a   &((ev ;;(pred p.p) nod state trail) (ev ;;(pred q.p) nod state trail))\
      %o   |((ev ;;(pred p.p) nod state trail) (ev ;;(pred q.p) nod state trail))\
      %n   !(ev ;;(pred p.p) nod state trail)\
      %w   ?.(=((gt nod) tag.p) & (ev ;;(pred p.p) nod state trail))\
      %x   (lien state |=(m=manx &(=((gt m) sibling.p) =((ga m sattr.p) (ga nod attr.p)))))\
    ==\
--\
\
++  shrub-schema\
  ^-  schema:anvil\
  :~\
  ::  structure (can't generate without these)\
  [%no-name 'shrub missing name' [%w 'shrub' [%n [%h 'name']]]]\
  [%no-shrub 'orphan behavior' [%w 'behavior' [%n [%x 'shrub' 'shrub' 'name']]]]\
  ::\
  ::  required children (codegen needs these nodes)\
  [%no-test 'if needs test' [%w 'if' [%n [%k 'test']]]]\
  [%no-then 'if needs then' [%w 'if' [%n [%k 'then']]]]\
  [%no-else 'if needs else' [%w 'if' [%n [%k 'else']]]]\
  [%no-otherwise 'match needs otherwise' [%w 'match' [%n [%k 'otherwise']]]]\
  [%no-over 'fold missing over' [%w 'fold' [%n [%h 'over']]]]\
  [%no-acc 'fold missing acc' [%w 'fold' [%n [%h 'acc']]]]\
  ::\
  ::  required attrs (can't generate gate/ref without name)\
  [%no-ref 'ref missing name' [%w 'ref' [%n [%h 'name']]]]\
  [%no-fn 'fn missing name' [%w 'fn' [%n [%h 'name']]]]\
  [%no-action-name 'action missing name' [%w 'action' [%n [%h 'name']]]]\
  ::\
  ::  context (generates wrong code if violated)\
  [%src-in-compute '%src in compute' [%w 'ref' [%a [%in 'compute'] [%a [%n [%in 'action']] [%b '%src' 'compute']]]]]\
  [%input-in-compute '%input in compute' [%w 'ref' [%a [%in 'compute'] [%a [%n [%in 'action']] [%b '%' 'compute']]]]]\
  [%create-in-compute 'create inside compute' [%w 'create' [%in 'compute']]]\
  ::\
  ::  def purity (generated gate would close over wrong scope)\
  [%def-slot 'def reads / path' [%w 'ref' [%a [%in 'def'] [%b '/' 'def']]]]\
  [%def-env 'def reads % binding' [%w 'ref' [%a [%in 'def'] [%b '%' 'def']]]]\
  ::\
  ::  pipe (can't chain less than 2)\
  [%short-pipe 'pipe needs 2+ children' [%w 'pipe' [%g '' 2]]]\
==\
--}